# PostgreSQL Database URL (Required)
# Use your NeonDB or any PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:port/dbname?sslmode=require

# JWT Secret (Required) - Used to sign and verify auth tokens
# Generate a strong random secret: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# OpenRouter API Key (Optional) - For AI chatbot feature
OPENROUTER_API_KEY=

# AI Model (Optional) - Default model for chatbot
MODEL=openai/gpt-4o